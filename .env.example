# Copy to `.env` in this folder and fill in values. `.env` is gitignored.

# --- Local dev (typical) — no Hostinger required ---
# MCI_DB_HOST=127.0.0.1
# MCI_DB_NAME=mycityinfo_local
# MCI_DB_USER=root
# MCI_DB_PASS=''

# --- Remote (e.g. Hostinger) — only if your IP is allowed to connect ---
MCI_DB_HOST=srv1518.hstgr.io
# Alternative hostname: 194.59.164.13
# If your host uses a non-default port, set it (otherwise omit):
# MCI_DB_PORT=3306
MCI_DB_NAME=mycityinfo_dev
MCI_DB_USER=your_db_user
MCI_DB_PASS='your_secure_password'
# Shared hosting often caps MySQL connects per hour (e.g. 500). Without this, each PHP
# request opens a new connection — easy to hit the cap under traffic or dev reloads.
# Enable persistent PDO connections (one per FPM worker, reused across requests):
# MCI_DB_PERSISTENT=1

# Application cache (home/listings + public API read models). Uses APCu on the server when enabled;
# otherwise JSON files under storage/cache/app/. Tune TTL (seconds) or disable for debugging.
# MCI_CACHE_TTL=120
# MCI_CACHE_DISABLE=1
# Public listing cache is also invalidated when a business is approved/edited (see mci_cache_invalidate_public).

# JWT signing secret for API tokens (use a long random string in production)
MCI_JWT_SECRET=change_this_to_a_long_random_hex_or_string

# Comma-separated reverse proxy IPs that may set X-Forwarded-For (e.g. your load balancer).
# If unset, client IP is taken only from REMOTE_ADDR (XFF is ignored — avoids spoofing).
# MCI_TRUSTED_PROXY_IPS=10.0.0.1,172.18.0.2

# Optional: extra browser origins allowed to call the JSON API with credentials (comma-separated).
# If unset, only requests whose Origin host matches the Host header get CORS reflection.
# MCI_ALLOWED_API_ORIGINS=https://app.example.com,https://staging.example.com

# Optional: include exception detail in 500 JSON from POST /api/v1/businesses (dev only; never in production)
# MCI_DEBUG_API=1

# Google OAuth — Login with Google (required for /auth/google/ to work)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://www.mycityinfo.com/auth/google/callback/
MCI_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
MCI_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth — Login with Facebook (required for /auth/facebook/ to work)
# Create app at https://developers.facebook.com/apps/
# Authorised redirect URI: https://www.mycityinfo.com/auth/facebook/callback/
MCI_FACEBOOK_APP_ID=your-facebook-app-id
MCI_FACEBOOK_APP_SECRET=your-facebook-app-secret

# --- Transactional email (PHPMailer + SMTP). Hostinger example; same keys work for Brevo later. ---
# Enable only when SMTP is configured (composer install required for PHPMailer).
# MCI_MAIL_ENABLED=1
# Canonical site URL for links inside emails (reset password, etc.)
# MCI_PUBLIC_SITE_URL=https://www.mycityinfo.com
# Hostinger SMTP (hPanel → Email → configuration)
# MCI_SMTP_HOST=smtp.hostinger.com
# MCI_SMTP_PORT=465
# MCI_SMTP_ENCRYPTION=ssl
# MCI_SMTP_USER=noreply@mycityinfo.com
# MCI_SMTP_PASS=your_mailbox_password
# MCI_MAIL_FROM=noreply@mycityinfo.com
# MCI_MAIL_FROM_NAME=My City Info
# Optional: where "Reply" in the mail client should go (human inbox)
# MCI_MAIL_REPLY_TO=hello@mycityinfo.com
# Optional override for support address in email bodies (defaults to hello@mycityinfo.com)
# MCI_CONTACT_EMAIL=hello@mycityinfo.com

# Optional — local/dev only (do not enable in production)
# Shows reset token + URL on /forgot-password/ after submit (in addition to email when mail is enabled).
# MCI_DEBUG_PASSWORD_RESET=1
# Allows manual social link from profile pages (OAuth should be used in production).
# MCI_ALLOW_DEV_SOCIAL_LINK=1

# --- WordPress import source (used by tools/wp_import/*.php) ---
# WP_DB_HOST=127.0.0.1
# WP_DB_PORT=3306
# WP_DB_NAME=wordpress_db
# WP_DB_USER=root
# WP_DB_PASS=''
# Optional (auto-detected from tables ending with "posts" if omitted)
# WP_TABLE_PREFIX=wp_
# Optional listing post types (comma separated)
# WP_LISTING_POST_TYPES=business,listing,place
# Optional category taxonomies (comma separated)
# WP_CATEGORY_TAXONOMIES=business_category,category
# Optional local filesystem path to wp-content/uploads for media copy
# WP_UPLOADS_PATH=C:\path\to\wordpress\wp-content\uploads
