RewriteRule ^forgot-password\.php$ forgot-password/index.php [L,QSA]
RewriteRule ^reset-password\.php$ reset-password/index.php [L,QSA]
RewriteRule ^logout\.php$ logout/index.php [L,QSA]
RewriteRule ^listing-preview\.php$ listing-preview/index.php [L,QSA]

RewriteRule ^cp/dashboard\.php$ cp/dashboard/index.php [L,QSA]
RewriteRule ^cp/users\.php$ cp/users/index.php [L,QSA]
RewriteRule ^cp/listings\.php$ cp/listings/index.php [L,QSA]
