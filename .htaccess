RewriteRule ^cp/coadmins\.php$ cp/coadmins/index.php [L,QSA]
RewriteRule ^cp/anonymous-business\.php$ cp/anonymous-business/index.php [L,QSA]

RewriteRule ^subscriber/dashboard\.php$ subscriber/dashboard/index.php [L,QSA]
RewriteRule ^subscriber/list-business\.php$ subscriber/list-business/index.php [L,QSA]
RewriteRule ^subscriber/listings\.php$ subscriber/listings/index.php [L,QSA]
RewriteRule ^subscriber/favourites\.php$ subscriber/favourites/index.php [L,QSA]
RewriteRule ^subscriber/enquiries\.php$ subscriber/enquiries/index.php [L,QSA]
RewriteRule ^subscriber/reviews\.php$ subscriber/reviews/index.php [L,QSA]
