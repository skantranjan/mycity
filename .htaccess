RewriteEngine On

# robots.txt → dynamic Sitemap line for current host
RewriteRule ^robots\.txt$ robots/index.php [L]

# Branded 404 (internal subrequest). If the app lives in a subdirectory, set this to /your-base/404/ instead.
ErrorDocument 404 /404/

# ------------------------------------------------------------
# OAuth social login callbacks
# ------------------------------------------------------------
RewriteRule ^auth/google/callback/?$ auth/google/callback/index.php [L,QSA]
RewriteRule ^auth/facebook/callback/?$ auth/facebook/callback/index.php [L,QSA]

# OAuth initiation redirects (handled by PHP pages)
RewriteRule ^auth/google/?$ auth/google/index.php [L,QSA]
RewriteRule ^auth/facebook/?$ auth/facebook/index.php [L,QSA]

# Common browser request fallback.
RewriteRule ^favicon\.ico$ assets/images/logo.png [L]

# ------------------------------------------------------------
# API routing: /api/v1/* -> api/v1/index.php
# ------------------------------------------------------------
RewriteRule ^api/v1/?(.*)$ api/v1/index.php [L,QSA]

# ------------------------------------------------------------
# Canonical redirects: .php URLs -> pretty URLs
# ------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+listings\.php[\s?] [NC]
RewriteRule ^listings\.php$ /business-listing/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+submit-listing\.php[\s?] [NC]
RewriteRule ^submit-listing\.php$ /submit-business-listing/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+register\.php[\s?] [NC]
RewriteRule ^register\.php$ /register/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+login\.php[\s?] [NC]
RewriteRule ^login\.php$ /login/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+about-us\.php[\s?] [NC]
RewriteRule ^about-us\.php$ /about/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+contact\.php[\s?] [NC]
RewriteRule ^contact\.php$ /contact/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+privacy-policy\.php[\s?] [NC]
RewriteRule ^privacy-policy\.php$ /privacy-policy/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+terms\.php[\s?] [NC]
RewriteRule ^terms\.php$ /terms-of-use/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+forgot-password\.php[\s?] [NC]
RewriteRule ^forgot-password\.php$ /forgot-password/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+reset-password\.php[\s?] [NC]
RewriteRule ^reset-password\.php$ /reset-password/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+logout\.php[\s?] [NC]
RewriteRule ^logout\.php$ /logout/ [R=301,L]

# Old /category/ and /terms/ paths -> renamed folders
RewriteRule ^category/(.+)$ /business-category/$1 [R=301,L]
RewriteRule ^category/?$ /business-category/ [R=301,L]
RewriteRule ^terms/?$ /terms-of-use/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+disclaimer\.php[\s?] [NC]
RewriteRule ^disclaimer\.php$ /disclaimer/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+cookies\.php[\s?] [NC]
RewriteRule ^cookies\.php$ /cookies/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+business\.php[\s?] [NC]
RewriteRule ^business\.php$ /business/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+listing-preview\.php[\s?] [NC]
RewriteRule ^listing-preview\.php$ /listing-preview/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+subscriber/dashboard\.php[\s?] [NC]
RewriteRule ^subscriber/dashboard\.php$ /subscriber/dashboard/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/list-business\.php[\s?] [NC]
RewriteRule ^subscriber/list-business\.php$ /subscriber/list-business/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/listings\.php[\s?] [NC]
RewriteRule ^subscriber/listings\.php$ /subscriber/listings/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/favourites\.php[\s?] [NC]
RewriteRule ^subscriber/favourites\.php$ /subscriber/favourites/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/enquiries\.php[\s?] [NC]
RewriteRule ^subscriber/enquiries\.php$ /subscriber/enquiries/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/reviews\.php[\s?] [NC]
RewriteRule ^subscriber/reviews\.php$ /subscriber/reviews/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/profile\.php[\s?] [NC]
RewriteRule ^subscriber/profile\.php$ /subscriber/profile/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/change-password\.php[\s?] [NC]
RewriteRule ^subscriber/change-password\.php$ /subscriber/change-password/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/logout\.php[\s?] [NC]
RewriteRule ^subscriber/logout\.php$ /subscriber/logout/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/listing-delete\.php[\s?] [NC]
RewriteRule ^subscriber/listing-delete\.php$ /subscriber/listing-delete/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+cp/dashboard\.php[\s?] [NC]
RewriteRule ^cp/dashboard\.php$ /cp/dashboard/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/users/?[\s?] [NC]
RewriteRule ^cp/users/?$ /cp/subscribers/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/users\.php[\s?] [NC]
RewriteRule ^cp/users\.php$ /cp/subscribers/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/listings\.php[\s?] [NC]
RewriteRule ^cp/listings\.php$ /cp/listings/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/anonymous-approvals\.php[\s?] [NC]
RewriteRule ^cp/anonymous-approvals\.php$ /cp/anonymous-approvals/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/profile\.php[\s?] [NC]
RewriteRule ^cp/profile\.php$ /cp/profile/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/change-password\.php[\s?] [NC]
RewriteRule ^cp/change-password\.php$ /cp/change-password/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/logout\.php[\s?] [NC]
RewriteRule ^cp/logout\.php$ /cp/logout/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/login\.php[\s?] [NC]
RewriteRule ^cp/login\.php$ /cp/login/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+cp/categories\.php[\s?] [NC]
RewriteRule ^cp/categories\.php$ /cp/categories/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/coadmins\.php[\s?] [NC]
RewriteRule ^cp/coadmins\.php$ /cp/coadmins/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/anonymous-business\.php[\s?] [NC]
RewriteRule ^cp/anonymous-business\.php$ /cp/anonymous-business/ [R=301,L]

# ------------------------------------------------------------
# Pretty URLs -> folder index.php entrypoints
# ------------------------------------------------------------
RewriteRule ^$ index.php [L]
RewriteRule ^sitemap-(common|businesses|business-categories|products|services|locations|tags)-([1-9][0-9]*)\.xml$ sitemap/index.php?kind=$1&part=$2 [L,QSA]
RewriteRule ^sitemap-(common|businesses|business-categories|products|services|locations|tags)\.xml$ sitemap/index.php?kind=$1 [L,QSA]
RewriteRule ^sitemap\.xml$ sitemap/index.php [L]
RewriteRule ^business-listing/?$ business-listing/index.php [L,QSA]
RewriteRule ^submit-business-listing/?$ submit-business-listing/index.php [L,QSA]
RewriteRule ^submit-listing/?$ /submit-business-listing/ [R=301,L,QSA]
RewriteRule ^register/?$ register/index.php [L,QSA]
RewriteRule ^login/?$ login/index.php [L,QSA]
RewriteRule ^about/?$ about/index.php [L,QSA]
RewriteRule ^robots/?$ robots/index.php [L,QSA]
RewriteRule ^404/?$ 404/index.php [L,QSA]
RewriteRule ^contact/?$ contact/index.php [L,QSA]
RewriteRule ^privacy-policy/?$ privacy-policy/index.php [L,QSA]
RewriteRule ^terms-of-use/?$ terms-of-use/index.php [L,QSA]
RewriteRule ^disclaimer/?$ disclaimer/index.php [L,QSA]
RewriteRule ^cookies/?$ cookies/index.php [L,QSA]
RewriteRule ^business/?$ business/index.php [L,QSA]
RewriteRule ^forgot-password/?$ forgot-password/index.php [L,QSA]
RewriteRule ^reset-password/?$ reset-password/index.php [L,QSA]
RewriteRule ^logout/?$ logout/index.php [L,QSA]
RewriteRule ^listing-preview/?$ listing-preview/index.php [L,QSA]
RewriteRule ^products/?$ products/index.php [L,QSA]
RewriteRule ^services/?$ services/index.php [L,QSA]

RewriteRule ^subscriber/dashboard/?$ subscriber/dashboard/index.php [L,QSA]
RewriteRule ^subscriber/list-business/?$ subscriber/list-business/index.php [L,QSA]
RewriteRule ^subscriber/listings/?$ subscriber/listings/index.php [L,QSA]
RewriteRule ^subscriber/favourites/?$ subscriber/favourites/index.php [L,QSA]
RewriteRule ^subscriber/enquiries/?$ subscriber/enquiries/index.php [L,QSA]
RewriteRule ^subscriber/reviews/?$ subscriber/reviews/index.php [L,QSA]
RewriteRule ^subscriber/profile/?$ subscriber/profile/index.php [L,QSA]
RewriteRule ^subscriber/change-password/?$ subscriber/change-password/index.php [L,QSA]
RewriteRule ^subscriber/logout/?$ subscriber/logout/index.php [L,QSA]
RewriteRule ^subscriber/listing-delete/?$ subscriber/listing-delete/index.php [L,QSA]

RewriteRule ^cp/dashboard/?$ cp/dashboard/index.php [L,QSA]
RewriteRule ^cp/subscribers/?$ cp/users/index.php [L,QSA]
RewriteRule ^cp/users/?$ cp/users/index.php [L,QSA]
RewriteRule ^cp/listings/awaiting-approval/?$ cp/listings/awaiting-approval/index.php [L,QSA]
RewriteRule ^cp/listings/draft/?$ cp/listings/draft/index.php [L,QSA]
RewriteRule ^cp/listings/live/?$ cp/listings/live/index.php [L,QSA]
RewriteRule ^cp/listings/rejected/?$ cp/listings/rejected/index.php [L,QSA]
RewriteRule ^cp/listings/suspended/?$ cp/listings/suspended/index.php [L,QSA]
RewriteRule ^cp/listings/anonymous/?$ cp/listings/anonymous/index.php [L,QSA]
RewriteRule ^cp/listings/admin-posted/?$ cp/listings/admin-posted/index.php [L,QSA]
RewriteRule ^cp/listings/?$ cp/listings/index.php [L,QSA]
RewriteRule ^cp/scraper/results/?$ cp/scraper/results/index.php [L,QSA]
RewriteRule ^cp/scraper/review/?$ cp/scraper/review/index.php [L,QSA]
RewriteRule ^cp/scraper/?$ cp/scraper/index.php [L,QSA]
RewriteRule ^cp/url-import/?$ cp/url-import/index.php [L,QSA]
RewriteRule ^cp/error-log/?$ cp/error-log/index.php [L,QSA]
RewriteRule ^cp/anonymous-approvals/?$ cp/anonymous-approvals/index.php [L,QSA]
RewriteRule ^cp/profile/?$ cp/profile/index.php [L,QSA]
RewriteRule ^cp/change-password/?$ cp/change-password/index.php [L,QSA]
RewriteRule ^cp/logout/?$ cp/logout/index.php [L,QSA]
RewriteRule ^cp/categories/?$ cp/categories/index.php [L,QSA]
RewriteRule ^cp/coadmins/?$ cp/coadmins/index.php [L,QSA]
RewriteRule ^cp/anonymous-business/?$ cp/anonymous-business/index.php [L,QSA]

# Legacy .php URLs (root/subscriber scripts removed; internal rewrite to folder entrypoints)
RewriteRule ^listings\.php$ business-listing/index.php [L,QSA]
RewriteRule ^business\.php$ business/index.php [L,QSA]
RewriteRule ^contact\.php$ contact/index.php [L,QSA]
RewriteRule ^cookies\.php$ cookies/index.php [L,QSA]
RewriteRule ^disclaimer\.php$ disclaimer/index.php [L,QSA]
RewriteRule ^login\.php$ login/index.php [L,QSA]
RewriteRule ^privacy-policy\.php$ privacy-policy/index.php [L,QSA]
