RewriteEngine On

# ------------------------------------------------------------
# Canonical redirects: .php URLs -> pretty URLs
# ------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+listings\.php[\s?] [NC]
RewriteRule ^listings\.php$ /business-listing/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+submit-listing\.php[\s?] [NC]
RewriteRule ^submit-listing\.php$ /submit-business-listing/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+register\.php[\s?] [NC]
RewriteRule ^register\.php$ /register/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+login\.php[\s?] [NC]
RewriteRule ^login\.php$ /login/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+about-us\.php[\s?] [NC]
RewriteRule ^about-us\.php$ /about/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+contact\.php[\s?] [NC]
RewriteRule ^contact\.php$ /contact/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+privacy-policy\.php[\s?] [NC]
RewriteRule ^privacy-policy\.php$ /privacy-policy/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+terms\.php[\s?] [NC]
RewriteRule ^terms\.php$ /terms/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+disclaimer\.php[\s?] [NC]
RewriteRule ^disclaimer\.php$ /disclaimer/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+cookies\.php[\s?] [NC]
RewriteRule ^cookies\.php$ /cookies/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+business\.php[\s?] [NC]
RewriteRule ^business\.php$ /business/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+listing-preview\.php[\s?] [NC]
RewriteRule ^listing-preview\.php$ /listing-preview/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+subscriber/dashboard\.php[\s?] [NC]
RewriteRule ^subscriber/dashboard\.php$ /subscriber/dashboard/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/list-business\.php[\s?] [NC]
RewriteRule ^subscriber/list-business\.php$ /subscriber/list-business/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/listings\.php[\s?] [NC]
RewriteRule ^subscriber/listings\.php$ /subscriber/listings/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/favourites\.php[\s?] [NC]
RewriteRule ^subscriber/favourites\.php$ /subscriber/favourites/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/enquiries\.php[\s?] [NC]
RewriteRule ^subscriber/enquiries\.php$ /subscriber/enquiries/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/reviews\.php[\s?] [NC]
RewriteRule ^subscriber/reviews\.php$ /subscriber/reviews/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/profile\.php[\s?] [NC]
RewriteRule ^subscriber/profile\.php$ /subscriber/profile/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/change-password\.php[\s?] [NC]
RewriteRule ^subscriber/change-password\.php$ /subscriber/change-password/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/logout\.php[\s?] [NC]
RewriteRule ^subscriber/logout\.php$ /subscriber/logout/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+subscriber/listing-delete\.php[\s?] [NC]
RewriteRule ^subscriber/listing-delete\.php$ /subscriber/listing-delete/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+cp/dashboard\.php[\s?] [NC]
RewriteRule ^cp/dashboard\.php$ /cp/dashboard/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/users\.php[\s?] [NC]
RewriteRule ^cp/users\.php$ /cp/users/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/listings\.php[\s?] [NC]
RewriteRule ^cp/listings\.php$ /cp/listings/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/anonymous-approvals\.php[\s?] [NC]
RewriteRule ^cp/anonymous-approvals\.php$ /cp/anonymous-approvals/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/profile\.php[\s?] [NC]
RewriteRule ^cp/profile\.php$ /cp/profile/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/change-password\.php[\s?] [NC]
RewriteRule ^cp/change-password\.php$ /cp/change-password/ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+cp/logout\.php[\s?] [NC]
RewriteRule ^cp/logout\.php$ /cp/logout/ [R=301,L]

# ------------------------------------------------------------
# Pretty URLs -> existing PHP entry points
# ------------------------------------------------------------
RewriteRule ^$ index.php [L]
RewriteRule ^business-listing/?$ listings.php [L,QSA]
RewriteRule ^submit-business-listing/?$ submit-listing.php [L,QSA]
RewriteRule ^register/?$ register.php [L,QSA]
RewriteRule ^login/?$ login.php [L,QSA]
RewriteRule ^about/?$ about-us.php [L,QSA]
RewriteRule ^contact/?$ contact.php [L,QSA]
RewriteRule ^privacy-policy/?$ privacy-policy.php [L,QSA]
RewriteRule ^terms/?$ terms.php [L,QSA]
RewriteRule ^disclaimer/?$ disclaimer.php [L,QSA]
RewriteRule ^cookies/?$ cookies.php [L,QSA]
RewriteRule ^business/?$ business.php [L,QSA]
RewriteRule ^listing-preview/?$ listing-preview.php [L,QSA]

RewriteRule ^subscriber/dashboard/?$ subscriber/dashboard.php [L,QSA]
RewriteRule ^subscriber/list-business/?$ subscriber/list-business.php [L,QSA]
RewriteRule ^subscriber/listings/?$ subscriber/listings.php [L,QSA]
RewriteRule ^subscriber/favourites/?$ subscriber/favourites.php [L,QSA]
RewriteRule ^subscriber/enquiries/?$ subscriber/enquiries.php [L,QSA]
RewriteRule ^subscriber/reviews/?$ subscriber/reviews.php [L,QSA]
RewriteRule ^subscriber/profile/?$ subscriber/profile.php [L,QSA]
RewriteRule ^subscriber/change-password/?$ subscriber/change-password.php [L,QSA]
RewriteRule ^subscriber/logout/?$ subscriber/logout.php [L,QSA]
RewriteRule ^subscriber/listing-delete/?$ subscriber/listing-delete.php [L,QSA]

RewriteRule ^cp/dashboard/?$ cp/dashboard.php [L,QSA]
RewriteRule ^cp/users/?$ cp/users.php [L,QSA]
RewriteRule ^cp/listings/?$ cp/listings.php [L,QSA]
RewriteRule ^cp/anonymous-approvals/?$ cp/anonymous-approvals.php [L,QSA]
RewriteRule ^cp/profile/?$ cp/profile.php [L,QSA]
RewriteRule ^cp/change-password/?$ cp/change-password.php [L,QSA]
RewriteRule ^cp/logout/?$ cp/logout.php [L,QSA]

# Keep existing category folder rewrites working
RewriteRule ^category/?$ category/index.php [L,QSA]

# Final fallback for legacy direct php requests and physical assets
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
