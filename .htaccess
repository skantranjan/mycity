RewriteRule ^cp/change-password\.php$ cp/change-password/index.php [L,QSA]
RewriteRule ^cp/logout\.php$ cp/logout/index.php [L,QSA]
RewriteRule ^cp/login\.php$ cp/login/index.php [L,QSA]
